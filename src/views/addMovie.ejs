<%- include('partials/header', { title: 'Add New Movie' }) %>

<div class="form-container">
    <h2>Add a New Movie</h2>

    <form action="/movies" method="POST" enctype="multipart/form-data">
        
        <div class="form-group">
            <label for="name">Movie Title:</label>
            <input type="text" id="name" name="name" required placeholder="e.g. The Matrix">
        </div>

        <div class="form-group">
            <label for="year">Release Year:</label>
            <input type="number" id="year" name="year" required min="1880" max="2099" value="2025">
        </div>

        <div class="form-group">
            <label for="actors">Actors (comma separated):</label>
            <input type="text" id="actors" name="actors" placeholder="e.g. Keanu Reeves, Laurence Fishburne">
            <small>Separate multiple names with commas</small>
        </div>

        <div class="form-group">
            <label for="genres">Genres (comma separated):</label>
            <input type="text" id="genres" name="genres" placeholder="e.g. Sci-Fi, Action">
        </div>

        <div class="form-group">
            <label for="image">Movie Poster:</label>
            <input type="file" id="image" name="image" accept="image/*">
        </div>

        <button type="submit" class="submit-btn">Add Movie</button>
    </form>
</div>

<%- include('partials/footer') %>