<%- include('partials/header', { title: title }) %>

<div class="form-container">
    <h2>Edit Movie: <%= movie.name %></h2>

    <form action="/movies/<%= movie.id %>/update" method="POST" enctype="multipart/form-data">
        
        <div class="form-group">
            <label for="name">Movie Title:</label>
            <input type="text" id="name" name="name" required value="<%= movie.name %>">
        </div>

        <div class="form-group">
            <label for="year">Release Year:</label>
            <input type="number" id="year" name="year" required min="1880" max="2099" value="<%= movie.year %>">
        </div>

        <div class="form-group">
            <label for="actors">Actors (comma separated):</label>
            <input type="text" id="actors" name="actors" value="<%= actorString %>">
        </div>

        <div class="form-group">
            <label for="genres">Genres (comma separated):</label>
            <input type="text" id="genres" name="genres" value="<%= genreString %>">
        </div>

        <div class="form-group">
            <label>Current Poster:</label>
            <% if (movie.image) { %>
                <img src="<%= movie.image %>" alt="Current Poster" style="width: 100px; display: block; margin-bottom: 10px;">
            <% } else { %>
                <p>No image uploaded.</p>
            <% } %>
            
            <label for="image">Upload New Poster (Leave empty to keep current):</label>
            <input type="file" id="image" name="image" accept="image/*">
        </div>

        <div class="actions">
            <button type="submit" class="submit-btn">Save Changes</button>
            <a href="/movies/<%= movie.id %>" style="margin-left: 10px; color: #666;">Cancel</a>
        </div>
    </form>
</div>

<%- include('partials/footer') %>